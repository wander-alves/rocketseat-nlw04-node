{
  "compilerOptions": {
    "lib": ["ES2024"],
    "target": "ES2024",
    "module": "commonjs",
    "esModuleInterop": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "strictPropertyInitialization": false
  }
}
